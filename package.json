  "scripts": {
    "init": "./scripts/setup.sh",
    "setup": "./scripts/setup.sh",
    "clean-setup": "./scripts/setup.sh --reset",
    "db:wipe": "./scripts/db.sh wipe",
    "db:push": "./scripts/db.sh push",
    "db:generate": "./scripts/db.sh generate",
    "db:reset": "./scripts/db.sh reset",
    "db:fresh": "./scripts/db.sh fresh",
    "start": "npm run dev",
    "dev": "./scripts/start-dev.sh",
    "start:server": "npx nx run sync-server:serve",
    "start:client": "npx nx run mobile-web:serve",
    "start:local": "npm run dev",
    "lint": "npx nx run-many -t lint --tui-auto-exit=true --nx-bail",
    "typecheck": "npx nx run-many -t typecheck --tui-auto-exit=true --nx-bail",
    "test": "npx nx run-many -t test --tui-auto-exit=true --nx-bail",
    "format": "npx nx format:write",
    "format:check": "npx nx format:check",
    "check-translations": "node scripts/check-translations.js",
    "check": "npm run check-translations && npm run typecheck -- --skip-nx-cache && npm run lint -- --skip-nx-cache && npm run test -- --skip-nx-cache && npm run format:check",
    "precommit": "./scripts/precommit.sh"
  },
