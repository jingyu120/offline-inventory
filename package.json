{
  "name": "@burma-inventory/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "setup": "npm install --no-audit",
    "start:local": "lsof -ti:8081,3000 | xargs kill -9 2>/dev/null; docker compose up -d && npx nx run sync-server:build:development && (npx nx run sync-server:build --configuration=watch & npx nx run-many -t serve -p sync-server mobile-web)",
    "db:wipe": "docker exec burma_inventory_db psql -U postgres -d inventory_db -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;'",
    "lint": "npx nx run-many -t lint --tui-auto-exit=true --nx-bail",
    "typecheck": "npx nx run-many -t typecheck --tui-auto-exit=true --nx-bail",
    "format": "npx nx format:write",
    "format:check": "npx nx format:check",
    "check": "npm run typecheck -- --skip-nx-cache && npm run lint -- --skip-nx-cache && npm run format:check"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "follow-redirects": "^1.15.11",
    "uuid": "^14.0.0",
    "yaml": "^2.8.2",
    "@hono/node-server": "^1.19.13",
    "@babel/runtime": "^7.26.0"
  },
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
