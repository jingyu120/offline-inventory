{
  "name": "shared-types",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "shared-types/src",
  "projectType": "library",
  "tags": ["scope:shared-types"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/shared-types",
        "main": "shared-types/src/index.ts",
        "tsConfig": "shared-types/tsconfig.lib.json",
        "assets": ["shared-types/*.md"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit -p shared-types/tsconfig.json"
      }
    }
  }
}
