{
  "name": "sync-server",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "sync-server/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "sync-server"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        },
        "watch": {
          "args": ["--node-env=development", "--watch"]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon --watch dist/sync-server/main.js --env-file=sync-server/.env dist/sync-server/main.js"
      }
    }
  },
  "tags": []
}
