{
  "name": "mobile-web",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "mobile-web/src",
  "projectType": "application",
  "tags": ["scope:mobile"],
  "targets": {
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "npx expo start --web --clear --non-interactive",
        "cwd": "mobile-web"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit -p mobile-web/tsconfig.json"
      }
    }
  }
}
