{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "useDefineForClassFields": false,
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@burma-inventory/shared-types": ["./shared-types/src/index.ts"],
      "@burma-inventory/ui-components": ["./ui-components/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
